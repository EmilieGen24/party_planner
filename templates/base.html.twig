<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Party Planner{% endblock %}</title>
        {# <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>"> #}
        <link rel="icon" type="image/png" href="{{ asset('../assets/img/favicon.png')}}" sizes="96x96" />
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </head>
    <body>
        <header>
            <nav class="container navbar">
                <div class="header-logo">
                    <img src="{{ asset('../assets/img/logo.png')}}" alt="Image du logo">
                </div>
                <div class="nav">
                    <ul class="links">
                        <li><a href="{{ path("accueil") }}">Accueil</a></li>
                        <li><a href="{{ path("galerie") }}">Thèmes</a></li>
                        {% if is_granted('IS_AUTHENTICATED_FULLY') %}
                            <li>
                                <a href="{{ path("app_logout") }}">Déconnexion</a>
                            </li>
                        {% else %}
                            <li><a href="{{ path("app_login") }}">Connexion</a></li>
                            <li><a href="{{ path("register") }}">Inscription</a></li>
                        {% endif %}

                        {# Accès administrateur #}
                        {% if is_granted('ROLE_ADMIN')%}
                        <li><a href="{{ path("admin") }}">Admin</a></li>
                        {% endif %}

                        <li><a href="{{ path("contact") }}">Contact</a></li>
                    </ul>
                     <!-- menu-burger avec fonction JS-->
                    <div class="menu-burger">
                        <img class="icon-burger" src="{{ asset('../assets/img/menu.png')}}" alt="Image du menu de navigation"> 
                    </div>
                </div>
            </nav>
        </header>
        {% block body %}{% endblock %}
         <footer>
            <section class="container">
                <div class="footer-content">
                    <div class="footer-logo">
                        <a href="{{ path("accueil") }}"><img src="{{ asset('../assets/img/logo.png')}}" alt="Image du logo"></a>
                    </div>
                    <a href="{{ path("mentions_legales") }}">Mentions légales</a>
                    <a href="{{ path("contact") }}">Formulaire de contact</a>
                    <div class="logo-reseaux">
                    <a href="https://www.facebook.com/" target="_blank">
                        <img src="{{ asset('../assets/img/logo_fb.png')}}" alt="Logo de Facebook">
                    </a>
                    <a href="https://www.pinterest.com/" target="_blank">
                        <img src="{{ asset('../assets/img/logo_pint.png')}}" alt="Logo de Pinterest">
                    </a>
                    <a href="https://www.instagram.com/" target="_blank">
                        <img src="{{ asset('../assets/img/logo_insta.png')}}" alt="Logo d'Instagram">
                    </a>
                    </div>
                </div>
                <div class="copy">
                    <p>Copyright 2026 Party Planner. Tous droits réservés.</p>
                </div>
            </section>
        </footer>
    </body>
</html>
